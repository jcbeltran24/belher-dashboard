{
  "_meta": {
    "project": "Agrícola Belher Dashboard",
    "version": "3.0",
    "updated": "2026-04-30",
    "engine": "Apache ECharts 5.5 + Chart.js 4.4",
    "principles": [
      "Dark-native: executive dark is the primary experience",
      "Glass-card language: subtle green micro-borders, glow on hover",
      "Data-first: ECharts gradient bars, smooth area fills",
      "4px grid, optical sizing, Apple-level precision",
      "Green-earth palette: deep forest backgrounds, emerald accents"
    ]
  },

  "color": {
    "brand": {
      "green-950": "#030807",
      "green-900": "#060d08",
      "green-800": "#0a1409",
      "green-700": "#111e13",
      "green-600": "#15803d",
      "green-500": "#16a34a",
      "green-400": "#22c55e",
      "green-300": "#34c759",
      "green-200": "#4ade80",
      "green-glow": "rgba(34,197,94,0.15)"
    },
    "amber": {
      "600": "#d97706",
      "400": "#fbbf24",
      "warm": "#ff9f0a"
    },
    "red": {
      "600": "#dc2626",
      "500": "#ef4444",
      "400": "#f87171",
      "bright": "#ff453a"
    },
    "blue": {
      "700": "#1d4ed8",
      "400": "#60a5fa"
    },
    "surface": {
      "dark-bg":     "#060d08",
      "dark-bg2":    "#091209",
      "dark-surface": "#0d1a10",
      "dark-card":   "#111e13",
      "dark-card2":  "#162419",
      "dark-border": "rgba(34,197,94,0.09)",
      "dark-border-hover": "rgba(34,197,94,0.22)",
      "light-bg":    "#f0f4f0",
      "light-card":  "#ffffff",
      "light-border":"rgba(0,0,0,0.08)"
    },
    "text": {
      "dark-primary":   "#dff0e3",
      "dark-secondary": "rgba(223,240,227,0.70)",
      "dark-muted":     "rgba(223,240,227,0.42)",
      "dark-disabled":  "rgba(223,240,227,0.20)"
    },
    "semantic": {
      "success":  "#34c759",
      "warning":  "#fbbf24",
      "danger":   "#ef4444",
      "info":     "#60a5fa",
      "neutral":  "rgba(255,255,255,0.5)"
    },
    "echarts-palette": [
      "rgba(34,197,89,0.85)",
      "#fbbf24",
      "#60a5fa",
      "#f87171",
      "#a78bfa",
      "#34d399"
    ]
  },

  "typography": {
    "family": {
      "sans": "'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Display', sans-serif",
      "mono": "'SF Mono', 'Fira Code', monospace"
    },
    "scale": {
      "2xs":  "0.60rem",
      "xs":   "0.70rem",
      "sm":   "0.78rem",
      "base": "0.875rem",
      "md":   "1.0rem",
      "lg":   "1.125rem",
      "xl":   "1.375rem",
      "2xl":  "1.65rem",
      "3xl":  "2.0rem",
      "4xl":  "2.4rem"
    }
  },

  "spacing": {
    "1": "4px",  "2": "8px",   "3": "12px", "4": "16px",
    "5": "20px", "6": "24px",  "7": "28px", "8": "32px",
    "10":"40px", "12":"48px",  "16":"64px"
  },

  "radius": {
    "xs": "4px", "sm": "8px", "md": "12px",
    "lg": "16px","xl": "22px","full": "9999px"
  },

  "shadow": {
    "dark": {
      "xs":  "0 1px 3px rgba(0,0,0,0.6)",
      "sm":  "0 2px 10px rgba(0,0,0,0.65), 0 1px 3px rgba(0,0,0,0.4)",
      "md":  "0 4px 24px rgba(0,0,0,0.6),  0 1px 6px rgba(0,0,0,0.35)",
      "lg":  "0 8px 36px rgba(0,0,0,0.7),  0 3px 10px rgba(0,0,0,0.45)",
      "xl":  "0 20px 56px rgba(0,0,0,0.8), 0 6px 16px rgba(0,0,0,0.5)",
      "glow-green": "0 0 0 1px rgba(34,197,94,0.22), 0 8px 36px rgba(0,0,0,0.7)",
      "glow-amber": "0 0 20px rgba(251,191,36,0.2)"
    }
  },

  "motion": {
    "duration": {
      "fast":   "150ms",
      "normal": "220ms",
      "slow":   "400ms"
    },
    "easing": {
      "standard":   "cubic-bezier(0.25, 0.46, 0.45, 0.94)",
      "decelerate": "cubic-bezier(0.0, 0.0, 0.2, 1.0)",
      "spring":     "cubic-bezier(0.34, 1.56, 0.64, 1.0)"
    }
  },

  "breakpoints": {
    "sm": "480px", "md": "640px",
    "lg": "900px", "xl": "1280px", "2xl": "1600px"
  }
}
